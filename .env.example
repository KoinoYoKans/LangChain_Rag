APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OPENAI_API_KEY=change-me
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=gpt-5.5

EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL_PATH=/models/embedding
HOST_EMBEDDING_MODEL_PATH=/opt/rag/models/Qwen3-Embedding-8B
EMBEDDING_DIMENSION=4096
RERANK_PROVIDER=local
LOCAL_RERANK_MODEL_PATH=/models/reranker
HOST_RERANK_MODEL_PATH=/opt/rag/models/Qwen3-Reranker-8B
RERANK_TOP_N=4
PGVECTOR_TABLE=rag_documents_4096

POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=Rag
POSTGRES_DSN=postgresql+psycopg://admin:change-me@postgres:5432/Rag
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL_MINUTES=1440
CORS_ALLOWED_ORIGINS=https://rag.example.com
TRUSTED_PROXY_CIDRS=172.30.0.0/24
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
RAG_EDGE_SUBNET=172.30.0.0/24
RAG_DATA_SUBNET=172.31.0.0/24
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_REMOTE_CONTENT_SIZE_BYTES=8388608
URL_FETCH_TIMEOUT_SECONDS=15
URL_FETCH_MAX_REDIRECTS=3
LOGIN_RATE_LIMIT=8
LOGIN_RATE_WINDOW_SECONDS=900
CHAT_RATE_LIMIT=30
API_RATE_LIMIT=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=false
WORKER_RECOVERY_INTERVAL_SECONDS=30
INGEST_RUNNING_STALE_SECONDS=1800
UPLOAD_STORAGE_DIR=storage/uploads
DEFAULT_ORG_NAME=Default Organization
DEFAULT_DEPARTMENT_NAME=Default Department
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-admin-password
